# Variables consumed by docker-compose.yml at the repo root.
# Copy this to .env and fill in real values. .env is git-ignored.

# Auth (optional until Phase 1 wires Auth.js — compose treats them as optional)
AUTH_SECRET=           # generate with: npx auth secret
GOOGLE_CLIENT_ID=      # single source of truth — compose feeds this to BOTH web (AUTH_GOOGLE_ID) and api
GOOGLE_CLIENT_SECRET=  # Google OAuth client secret (web only)

# Dev/testing-only: skips the entire auth flow (backend AuthFilter + frontend proxy/api)
# when set to true. Default false — auth is enforced unless explicitly opted out.
SKIP_AUTH=false
