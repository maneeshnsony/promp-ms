#--------------------------------------------------------------------
# Example Environment Configuration file
#
# Copy this to backend/.env and fill in real values. backend/.env is
# git-ignored — never commit real secrets.
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# ENVIRONMENT
#--------------------------------------------------------------------

CI_ENVIRONMENT = production

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------

app.baseURL = 'http://localhost:8080/'
# app.forceGlobalSecureRequests = false
# app.CSPEnabled = false

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------

database.default.hostname = host.docker.internal
database.default.database = prompt_ms
database.default.username = postgres
database.default.password = change_me
database.default.DBDriver = Postgre
database.default.charset = utf8
database.default.port = 5432

#--------------------------------------------------------------------
# ENCRYPTION
#--------------------------------------------------------------------

# encryption.key =

#--------------------------------------------------------------------
# SESSION
#--------------------------------------------------------------------

# session.driver = 'CodeIgniter\Session\Handlers\FileHandler'
# session.savePath = null

#--------------------------------------------------------------------
# LOGGER
#--------------------------------------------------------------------

# logger.threshold = 4

#--------------------------------------------------------------------
# PROMPT HUB — GOOGLE OAUTH / SESSION JWT
#--------------------------------------------------------------------

# GOOGLE_CLIENT_ID lives in the root .env only — docker-compose injects it into the
# api container, so the backend `aud` check can never drift from the frontend's value.
GOOGLE_ALLOWED_DOMAIN =                         # optional — restrict sign-in to one Workspace domain
APP_JWT_SECRET        = change_me_to_a_long_random_string
